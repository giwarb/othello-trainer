{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm:build": "node src/engine/build-wasm.mjs",
    "predev": "npm run wasm:build",
    "dev": "vite",
    "prebuild": "npm run wasm:build",
    "build": "tsc -b && vite build && node scripts/inject-sw-version.mjs",
    "preview": "vite preview",
    "pretypecheck": "npm run wasm:build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "joseki:build": "node --experimental-strip-types src/joseki/generate.ts",
    "puzzles:build": "node --experimental-strip-types ../puzzlegen/generate.ts"
  },
  "dependencies": {
    "preact": "^10.29.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^24.13.2",
    "fake-indexeddb": "^6.2.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
